# Force the lockfile to record sharp + libvips binaries for the platforms we
# actually deploy to (Vercel = linux-x64) in addition to whatever the local
# install host happens to be. Without these, the lockfile captures only the
# install-host's platform and `npm ci` on Vercel skips the linux-x64 sharp
# binary, breaking /api/favicon and any other sharp consumer.
supportedArchitectures[os][]=linux
supportedArchitectures[os][]=darwin
supportedArchitectures[cpu][]=x64
supportedArchitectures[cpu][]=arm64
supportedArchitectures[libc][]=glibc
